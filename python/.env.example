# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Amazon Bedrock
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# Amazon S3
S3_BUCKET_NAME=risk-analysis-docs

# Amazon DynamoDB
DYNAMODB_TABLE_NAME=risk-analysis-results

# Application
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO
