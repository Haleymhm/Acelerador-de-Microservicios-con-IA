# Puerto para el servidor
PORT=3000

# URL de conexión para la base de datos PostgreSQL
# Formato: postgres://user:password@host:port/database
DATABASE_URL=postgres://postgres:password@localhost:5432/mydatabase

# Configuración de AWS
AWS_REGION=us-east-1

# Credenciales de AWS (no recomendado para producción, usar roles de IAM)
# Descomentar y rellenar solo para desarrollo local si es necesario.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
